local StyleTab = Window:CreateTab("Fighting Styles", 104575428877547)  
StyleTab:CreateSection("Styles")  

local function setStyle(style)  
	LocalPlayer:SetAttribute("FightingStyle", style)  
end  

local styles = {  
	"Default","Leg Kick","Ultra Goku","Naruto",  
	"Luffy","Spiked Purse","Headless Horseman",  
	"Gojo","Midnight Blade"  
}  

for _, style in ipairs(styles) do  
	StyleTab:CreateButton({  
		Name = style,  
		Callback = function()  
			setStyle(style)  
		end  
	})  
end  

StyleTab:CreateToggle({  
	Name = "Cycle Styles (Loop)",  
	CurrentValue = false,  
	Callback = function(state)  
		if state then  
			task.spawn(function()  
				while state do  
					for _, style in ipairs(styles) do  
						if not state then break end  
						setStyle(style)  
						task.wait(1)  
					end  
				end  
			end)  
		end  
	end  
})  
